---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title="Paddy McNabb"
  description="LLM inference optimisation on RISC-V — kernel engineering, microarchitectural analysis, and cycle-accurate benchmarking."
>
  <div class="index-content framed">
    <h1 id="hello-there">LLMs on RISC-V</h1>
    <p>
      Kernel engineering and performance analysis for LLM inference on RISC-V hardware.
      This blog documents experiments across both software and hardware modelling — from RVV 
      intrinsics, register pressure analysis, and LLVM IR metrics, to QEMU emulation and 
      cycle-accurate gem5 simulation.
    </p>
    <p>
      Current focus: extending llama.cpp GEMM kernels for the RISC-V Vector Extension (RVV),
      validated against both simulated and physical targets.
    </p>
    <p>
      — <a href="/about/">Paddy McNabb</a> · AI Engineer · Edinburgh
      · <a href="https://github.com/paddymac83" target="_blank" rel="noopener">GitHub</a>
      · <a href="https://linkedin.com/in/paddy-mcnabb" target="_blank" rel="noopener">LinkedIn</a>
    </p>
  </div>

  <div class="posts">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>