---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title="Paddy McNabb"
  description="LLM inference optimisation on RISC-V — kernel engineering, microarchitectural analysis, and cycle-accurate benchmarking."
>
  <div class="index-content framed">
    <h1 id="hello-there">LLMs on RISC-V</h1>
    <p>
      Kernel engineering and performance analysis for LLM inference on RISC-V hardware.
      This blog documents experiments at every level of the stack — from RVV intrinsics and
      register pressure analysis, to QEMU emulation, LLVM IR metrics, and cycle-accurate
      gem5 simulation.
    </p>
    <p>
      Current focus: extending llama.cpp GEMM kernels for the RISC-V Vector Extension (RVV),
      targeting in-order cores representative of the SiFive X280-class edge AI family.
      Next step: validation on physical hardware — Milk-V Pioneer and StarFive VisionFive 2.
    </p>
    <p>
      — <a href="/about/">Paddy McNabb</a> · Senior AI Engineer · Edinburgh
      · <a href="https://github.com/paddymac83" target="_blank" rel="noopener">GitHub</a>
      · <a href="https://linkedin.com/in/paddy-mcnabb" target="_blank" rel="noopener">LinkedIn</a>
    </p>
  </div>

  <div class="posts">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>